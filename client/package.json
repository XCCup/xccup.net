{
  "name": "xccup-client",
  "version": "0.2.0",
  "private": true,
  "license": "GNU GPLv3",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "build-local": "vue-tsc --noEmit && vite build --mode staging",
    "serve": "vite preview --host",
    "preview": "vue-tsc --noEmit && vite build --mode staging && vite preview --host",
    "preview-8000": "vue-tsc --noEmit && vite build --mode staging && vite preview --host --port 8000",
    "cypress-gui": "cypress open",
    "cypress-headless": "cypress run",
    "lint": "eslint --ext .js,.vue,.ts --ignore-path .gitignore --fix src",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier .  --write",
    "up": "npx taze -I"
  },
  "dependencies": {
    "@sentry/tracing": "^7.120.4",
    "@sentry/vue": "^10.37.0",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "@vueuse/core": "^14.1.0",
    "@vueuse/integrations": "^14.1.0",
    "axios": "^1.13.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-luxon": "^1.3.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "glightbox": "^3.3.1",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "leaflet-gesture-handling": "^1.2.2",
    "lodash-es": "^4.17.23",
    "luxon": "^3.7.2",
    "marked": "^17.0.1",
    "metar-parser": "^1.0.1",
    "nprogress": "^0.2.0",
    "sweetalert2": "^11.26.17",
    "v-plausible": "^1.2.0",
    "vue": "^3.5.27",
    "vue-avatar-editor-improved": "^1.0.7",
    "vue-demi": "^0.14.10",
    "vue-router": "^4.6.4",
    "vue3-datepicker": "^0.4.0",
    "vue3-emoji-picker": "^1.1.8"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^4.8.0",
    "@types/bootstrap": "^5.2.10",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.0.10",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-typescript": "^14.6.0",
    "autoprefixer": "^10.4.23",
    "cypress": "^15.9.0",
    "cypress-file-upload": "^5.0.8",
    "cypress-terminal-report": "^7.3.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^5.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.7.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "win32",
        "darwin",
        "linux",
        "current"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    }
  }
}
