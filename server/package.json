{
  "name": "xccup-server",
  "version": "0.1.0",
  "description": "The backend server for the xccup",
  "private": true,
  "license": "GNU GPLv3",
  "main": "app.js",
  "scripts": {
    "start": "ts-node --transpile-only app.ts",
    "dev": "ts-node-dev --poll --respawn --pretty --transpile-only app.ts",
    "docker-dev": "docker compose up",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "up": "docker compose run --rm npm npx taze -I",
    "format": "prettier .  --write",
    "docker-install": "docker compose run --rm npm npm install"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@sentry/node": "^10.37.0",
    "@sentry/profiling-node": "^10.37.0",
    "adm-zip": "^0.5.16",
    "axios": "1.6.2",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "bs-logger": "^0.2.6",
    "compression": "^1.8.1",
    "convict": "^6.2.4",
    "core-js": "^3.48.0",
    "cors": "^2.8.6",
    "date-easter": "^1.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "exifr": "^7.1.3",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "flight-recorder-manufacturers": "^2.0.0",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "morgan": "^1.10.1",
    "multer": "1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "node-html-parser": "^7.0.2",
    "nodemailer": "^8.0.5",
    "parse-dms": "^0.0.5",
    "pg": "^8.17.2",
    "pg-hstore": "^2.3.4",
    "prettier": "^3.8.1",
    "sanitize-html": "^2.17.0",
    "sequelize": "^6.37.7",
    "sharp": "^0.33.5",
    "timekeeper": "^2.3.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "uuid": "^11.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/convict": "^6.1.6",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.23",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.9",
    "@types/sanitize-html": "^2.16.0",
    "cross-env": "^10.1.0",
    "csv-parser": "^3.2.0",
    "eslint": "^8.57.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "win32",
        "darwin",
        "linux",
        "current"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    }
  },
  "packageManager": "pnpm@10.28.2"
}
